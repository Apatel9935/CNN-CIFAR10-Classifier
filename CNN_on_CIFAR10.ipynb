      "source": [
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.optim as optim\n",
        "\n",
        "import torchvision\n",
        "from torchvision.datasets import CIFAR10"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "-8kqk8c3DMX6"
      },
      "outputs": [],
      "source": [
        "# Datasets and DataLoaders\n",
        "\n",
        "from torch.utils.data import DataLoader\n",
        "import torchvision.transforms as transforms\n",
        "\n",
        "# image => scale(0,1) => normalize(-1,1)\n",
        "transfrom = transforms.Compose([\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize((0.5,0.5,0.5),(0.5,0.5,0.5))\n",
        "])\n",
        "\n",
        "\n",
        "trainset = CIFAR10(root = \"./data\" , train = True , download = True , transform = transfrom)    ,
        "testset = CIFAR10(root = \"./data\" , train = False , download = True , transform = transfrom)     "
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "r4muSWqKOBA0",
        "outputId": "cbb728a9-17e7-46a4-b9c4-292232ff4da9"
      },
      "outputs": [
        {
          "data": {
            "text/plain": [
              "Dataset CIFAR10\n",
              "    Number of datapoints: 50000\n",
              "    Root location: /content/drive/My Drive/Colab Notebooks/DLDataset/CNN_CIFAR10\n",
              "    Split: Train\n",
              "    StandardTransform\n",
              "Transform: Compose(\n",
              "               ToTensor()\n",
              "               Normalize(mean=(0.5, 0.5, 0.5), std=(0.5, 0.5, 0.5))\n",
              "           )"
            ]
          },
          "execution_count": 8,
          "metadata": {},
          "output_type": "execute_result"
        }
      ],
      "source": [
        "trainset\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "7PT7JMHF5PMG"
      },
      "outputs": [],
      "source": [
        "trainloader = DataLoader(trainset , batch_size = 64 , shuffle =True)\n",
        "testloader = DataLoader(testset , batch_size = 64)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "BdBeJ9M97hkw"
      },
      "source": [
        "# **Build a CNN**"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "tNj1g62g7rJq"
      },
      "outputs": [],
      "source": [
        "class CNN(nn.Module):\n",
        "\n",
        "  def __init__(self):\n",
        "    super().__init__()\n",
        "\n",
        "    self.conv_layers = nn.Sequential(\n",
        "        nn.Conv2d(in_channels = 3, out_channels = 32 , kernel_size = 3 , padding = 1),\n",
        "        nn.ReLU(),\n",
        "        nn.MaxPool2d(kernel_size= 2 , stride = 2),\n",
        "\n",
        "        nn.Conv2d(in_channels = 32, out_channels = 64 , kernel_size = 3 , padding = 1),\n",
        "        nn.ReLU(),\n",
        "        nn.MaxPool2d(kernel_size= 2 , stride = 2),\n",
        "\n",
        "        nn.Conv2d(in_channels = 64, out_channels = 128 , kernel_size = 3 , padding = 1),\n",
        "        nn.ReLU(),\n",
        "        nn.MaxPool2d(kernel_size= 2 , stride = 2),\n",
        "\n",
        "    )\n",
        "\n",
        "    self.fc_layers = nn.Sequential(\n",
        "        nn.Linear(4*4*128 , 256),\n",
        "        nn.ReLU(),\n",
        "\n",
        "        nn.Linear(256,10)\n",
        "    )\n",
        "\n",
        "  def forward(self,x):\n",
        "    x = self.conv_layers(x)\n",
        "    x = x.view(x.size(0),-1)         # Flatten\n",
        "    x = self.fc_layers(x)\n",
        "\n",
        "    return x\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "SrUJcAmkSP2z"
      },
      "outputs": [],
      "source": [
        "model = CNN()\n",
        "\n",
        "criterian = nn.CrossEntropyLoss()\n",
        "optimizer = optim.Adam(model.parameters())"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "bAxGDn1VS8gc"
      },
      "source": [
        "# **Training CNN**"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "ZMaHJHpjTEzY",
        "outputId": "99a97f67-bb39-4a9f-9e27-d34c9e0120f1"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "epoch = 1 and loss = 1.3537945527097452\n",
            "epoch = 2 and loss = 0.9372129623237473\n",
            "epoch = 3 and loss = 0.7495216208193308\n",
            "epoch = 4 and loss = 0.6221282477955075\n",
            "epoch = 5 and loss = 0.520751334288541\n",
            "epoch = 6 and loss = 0.4314468485848678\n",
            "epoch = 7 and loss = 0.34102924941750745\n",
            "epoch = 8 and loss = 0.27145471964079093\n",
            "epoch = 9 and loss = 0.20681468753711038\n",
            "epoch = 10 and loss = 0.16583301065980321\n"
          ]
        }
      ],
      "source": [
        "model.train()\n",
        "epochs = 10\n",
        "\n",
        "for epoch in range(epochs):\n",
        "  epoch_training_loss = 0.0         # overall loss after training 1 epoch\n",
        "\n",
        "  for images , labels in trainloader:\n",
        "    optimizer.zero_grad()\n",
        "\n",
        "    output = model.forward(images)       #forward propogation\n",
        "    loss = criterian(output,labels)      # loss fxn\n",
        "    loss.backward()                      # backward propogation\n",
        "    optimizer.step()                     # update parameter\n",
        "\n",
        "    epoch_training_loss += loss.item()\n",
        "\n",
        "  print(f\"epoch = {epoch+1} and loss = {epoch_training_loss/len(trainloader)}\")\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "1insI83OZYAd",
        "outputId": "8dfc9455-a3f0-4c2f-e09f-59d0fa8e122c"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Accuracy =  75.91 %\n"
          ]
        }
      ],
      "source": [
        "# Evaluating\n",
        "model.eval()\n",
        "\n",
        "correct_labels = 0\n",
        "total_labels = 0\n",
        "\n",
        "with torch.no_grad():\n",
        "  for images , labels in testloader:\n",
        "    outputs = model.forward(images)\n",
        "    _,predicted = torch.max(outputs,1)\n",
        "    correct_labels += (predicted == labels ).sum().item()\n",
        "    total_labels += labels.size(0)\n",
        "\n",
        "print(\"Accuracy = \", correct_labels/total_labels  * 100 , \"%\")\n",
        "\n"
      ]
    }
  ],
